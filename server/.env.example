# ============================================
# OmniGuard Production Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to version control
# ============================================

PORT=3001
NODE_ENV=production

# REQUIRED: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# MySQL / MariaDB connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=omniguard
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_NAME=omniguard

# CORS — set to your actual frontend domain in production
ALLOWED_ORIGIN=https://yourdomain.com

# Initial admin seeding (used only by init-db.js on first run — remove after seeding)
INITIAL_ADMIN_EMAIL=admin@campus.edu
INITIAL_ADMIN_PASSWORD=REPLACE_WITH_STRONG_INITIAL_PASSWORD
